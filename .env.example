# --- Runtime mode -----------------------------------------------------------
# true  = no external services needed: seed emails, fake calendar, outbox dir
# false = real Gmail + Google Calendar (requires Google OAuth credentials)
DEMO_MODE=true

# --- Database ----------------------------------------------------------------
# SQLite for demo; swap for PostgreSQL in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/bookings
DATABASE_URL=sqlite:///./data/bookings.db

# --- Scheduler ----------------------------------------------------------------
POLL_INTERVAL_MINUTES=10

# --- Claude fallback extraction (optional) ------------------------------------
# Leave empty to disable the LLM fallback entirely; unparseable emails then go
# straight to the ONHOLD review queue.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Google APIs (only used when DEMO_MODE=false) ------------------------------
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary
# Gmail search query used by the poller
GMAIL_QUERY=is:unread label:bookings

# --- Company details (appear on invoices and confirmation emails) --------------
COMPANY_NAME=Company A
COMPANY_EMAIL=bookings@example.com
COMPANY_ADDRESS=1 Example Street, Example Town, EX1 2MP
VAT_RATE=0.20

# --- Booking rules --------------------------------------------------------------
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=17
APPOINTMENT_DURATION_MINUTES=60

# --- Paths -----------------------------------------------------------------------
INVOICE_DIR=data/invoices
OUTBOX_DIR=data/outbox
SEED_EMAILS_FILE=seed/emails.json
